# Secrets — never commit env files with real values
.env
.env.local
.env.production.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
*.jks
*credential*
*secret*

# OpenClaw runtime config — installed plugins, logs, and other runtime state.
# openclaw.json is tracked (contains __OPENROUTER_API_KEY__ placeholder, not real key).
# extensions/mem9/ is tracked (the mem9 plugin source, installed from @mem9/openclaw).
config/openclaw/*
!config/openclaw/.gitkeep
!config/openclaw/openclaw.json
!config/openclaw/extensions/
!config/openclaw/extensions/mem9/

# mnemo config — same pattern
config/mnemo/*
!config/mnemo/.gitkeep

# Runtime data
workspace/repo/
workspace/.orchestrator-stats.json
*.log

# OS
.DS_Store
Thumbs.db

# Docker
tidb-data/

# BFG Repo-Cleaner reports
*.bfg-report/
*.bfg-report
..bfg-report/

# Editor
.vscode/
.idea/
*.swp
*.swo
