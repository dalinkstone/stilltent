# Secrets — never commit env files with real values
.env
.env.local
.env.production.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
*.jks
*credential*
*secret*

# OpenClaw runtime config — contains auto-generated gateway auth tokens,
# installed plugins, logs, and other runtime state. Only .gitkeep is tracked.
config/openclaw/*
!config/openclaw/.gitkeep

# mnemo config — same pattern
config/mnemo/*
!config/mnemo/.gitkeep

# Runtime data
workspace/repo/
workspace/.orchestrator-stats.json
*.log

# OS
.DS_Store
Thumbs.db

# Docker
tidb-data/

# BFG Repo-Cleaner reports
*.bfg-report/
*.bfg-report
..bfg-report/

# Editor
.vscode/
.idea/
*.swp
*.swo
