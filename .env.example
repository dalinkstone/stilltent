# === GitHub ===
# Fine-grained PAT with 'repo' + 'workflow' scope on the target repository
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Target repository in owner/name format
TARGET_REPO=your-username/your-repo-name

# === LLM Provider (OpenRouter) ===
# Get your API key at https://openrouter.ai/keys
# Browse models at https://openrouter.ai/models
#
# Model: qwen3-coder-next — purpose-built for agentic coding
#   $0.12/M input, $0.75/M output, 262K context, 65K max output
#   Budget: ~$50 for 5-day continuous run (120 hours)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=qwen/qwen3-coder-next

# === Embedding (local C service — no external API cost) ===
# The embed-service container produces 256-dim L2-normalized vectors locally.
# EMBEDDING_PROVIDER=ollama tells mnemo-server to use the local OpenAI-compatible
# embed API (not actual Ollama — the code path name is a legacy misnomer).
EMBEDDING_MODEL=local-embed
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=256

# === TiDB ===
TIDB_HOST=tidb
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=mnemos

# === mnemo-server (mem9) ===
MEM9_API_PORT=8082
MEM9_API_KEY=stilltent-local-dev-key

# === OpenClaw ===
OPENCLAW_PORT=18789
# Gateway auth token (must match gateway.auth.token in config/openclaw/openclaw.json)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# === Orchestrator ===
# Seconds between loop iterations (default: 60 = 1 minute pause between cycles)
LOOP_INTERVAL=60
# Cooldown pause between iterations in seconds (default: 30)
COOLDOWN_SECONDS=30
# Maximum seconds per iteration before the watchdog kills it
ITERATION_TIMEOUT=600
# Number of consecutive failures before the orchestrator pauses (default: 25)
MAX_CONSECUTIVE_FAILURES=25
# Total runtime limit in hours before graceful shutdown (5 days = 120 hours)
TOTAL_RUNTIME_HOURS=120
# Total budget limit in dollars for the full run (orchestrator pauses if projected spend exceeds this)
BUDGET_LIMIT=50
# Daily budget limit in dollars (fallback guard)
DAILY_BUDGET_LIMIT=15

# === Deployment ===
# For DigitalOcean VPS, no special config needed beyond the above.
# Ensure Docker and Docker Compose are installed on the droplet.
# Recommended droplet: 8GB RAM / 2 Intel vCPU / 160GB disk ($48/mo)
# No GPU required — all inference is via OpenRouter API.
