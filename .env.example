# === GitHub ===
# Fine-grained PAT with 'repo' + 'workflow' scope on the target repository
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Target repository in owner/name format
TARGET_REPO=your-username/your-repo-name

# === LLM Provider (OpenRouter) ===
# Get your API key at https://openrouter.ai/keys
# Browse models at https://openrouter.ai/models
#
# Cheap recommended models for long autonomous runs:
#   deepseek/deepseek-chat-v3-0324  (~$0.27/M input, $1.10/M output)
#   meta-llama/llama-4-scout        (~free tier available)
#   google/gemini-2.0-flash-001     (~$0.10/M input)
#
# For embeddings, text-embedding-3-small is $0.02/M tokens
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_PROVIDER=openrouter
EMBEDDING_DIM=1536

# === TiDB ===
TIDB_HOST=tidb
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=mnemos

# === mnemo-server (mem9) ===
MEM9_API_PORT=8082
MEM9_API_KEY=stilltent-local-dev-key

# === OpenClaw ===
OPENCLAW_PORT=18789

# === Orchestrator ===
# Seconds between loop iterations (default: 60 = 1 minute pause between cycles)
LOOP_INTERVAL=60
# Maximum seconds per iteration before the watchdog kills it
ITERATION_TIMEOUT=600
# Number of consecutive failures before the orchestrator pauses
MAX_CONSECUTIVE_FAILURES=10

# === Deployment ===
# For DigitalOcean VPS, no special config needed beyond the above.
# Ensure Docker and Docker Compose are installed on the droplet.
# Recommended droplet: 4GB RAM / 2 vCPU ($24/mo or use free credits)
# No GPU required — all inference is via OpenRouter API.
