# ═══════════════════════════════════════════════════════════════════
# stilltent — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────
# You need TARGET_REPO + at least one LLM API key to get started.

# GitHub fine-grained PAT with 'repo' + 'workflow' scope on the target repository
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Target repository in owner/name format
TARGET_REPO=your-username/your-repo-name

# ── LLM Provider (OpenRouter — default) ─────────────────────────
# Get your API key at https://openrouter.ai/keys
# Browse models at https://openrouter.ai/models
#
# Model: qwen3-coder-next — purpose-built for agentic coding
#   $0.12/M input, $0.75/M output, 262K context, 65K max output
#   Budget: ~$50 for 5-day continuous run (120 hours)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
OPENROUTER_MODEL=qwen/qwen3-coder-next

# ── Agent Runtime ────────────────────────────────────────────────
# Configure whichever agent runtime you selected in stilltent.yml

# OpenClaw (default)
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# NanoClaw (lightweight, uses Anthropic directly)
# NANOCLAW_PORT=18790
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# NemoClaw (NVIDIA OpenShell)
# NEMOCLAW_PORT=18791
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx

# ── Memory Backend ───────────────────────────────────────────────

# Embedding (local C service — no external API cost)
# The embed-service container produces 256-dim L2-normalized vectors locally.
EMBEDDING_MODEL=local-embed
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIM=256

# TiDB (used by mem9 backend)
TIDB_HOST=tidb
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=mnemos

# mem9 API
MEM9_API_PORT=8082
MEM9_API_KEY=stilltent-local-dev-key

# Supermemory (SaaS alternative to self-hosted mem9)
# SUPERMEMORY_API_KEY=sm-xxxxxxxxxxxx
# SUPERMEMORY_BASE_URL=https://api.supermemory.ai

# ── Sandbox ──────────────────────────────────────────────────────

# Daytona (cloud sandbox provider)
# DAYTONA_API_KEY=dtn-xxxxxxxxxxxx
# DAYTONA_BASE_URL=https://app.daytona.io

# ── Orchestrator ─────────────────────────────────────────────────

# Seconds between loop iterations (default: 60)
LOOP_INTERVAL=60
# Cooldown pause between iterations in seconds
COOLDOWN_SECONDS=30
# Maximum seconds per iteration before watchdog kills it
ITERATION_TIMEOUT=600
# Consecutive failures before orchestrator pauses
MAX_CONSECUTIVE_FAILURES=25
# Total runtime limit in hours (5 days = 120)
TOTAL_RUNTIME_HOURS=120
# Total budget limit in dollars
BUDGET_LIMIT=50
# Daily budget limit in dollars (fallback guard)
DAILY_BUDGET_LIMIT=15

# ── Deploy: VPS Providers ────────────────────────────────────────

# DigitalOcean
# DROPLET_IP=xxx.xxx.xxx.xxx
# DIGITALOCEAN_TOKEN=dop_v1_xxxxxxxxxxxx
# DO_REGION=sfo3
# DO_SIZE=s-2vcpu-8gb

# Vultr
# VULTR_IP=xxx.xxx.xxx.xxx
# VULTR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VULTR_REGION=ewr
# VULTR_PLAN=vc2-2c-4gb

# ── Deploy: PaaS Providers ──────────────────────────────────────

# Railway
# RAILWAY_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Render
# RENDER_API_KEY=rnd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Heroku
# HEROKU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HEROKU_APP_NAME=stilltent

# ── Deploy: Common ──────────────────────────────────────────────

# Git branch and repo URL used by deploy scripts
# DEPLOY_BRANCH=main
# DEPLOY_REPO_URL=https://github.com/dalinstone/stilltent.git

# ── Claude Code (alternative agent backend) ──────────────────────

# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
