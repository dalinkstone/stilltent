# === GitHub ===
# Fine-grained PAT with 'repo' + 'workflow' scope on the target repository
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Target repository in owner/name format
TARGET_REPO=your-username/your-repo-name

# === Ollama (host-native, not containerized) ===
# The endpoint the containers use to reach Ollama on the host
# macOS/Windows Docker Desktop: host.docker.internal
# Linux: 172.17.0.1 (or use extra_hosts in compose)
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen3:32b
OLLAMA_EMBED_MODEL=nomic-embed-text

# === TiDB ===
TIDB_HOST=tidb
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=mnemos

# === mnemo-server (mem9) ===
MEM9_API_PORT=8082
MEM9_API_KEY=stilltent-local-dev-key

# === OpenClaw ===
OPENCLAW_PORT=3000

# === Orchestrator ===
# Seconds between loop iterations (default: 60 = 1 minute pause between cycles)
LOOP_INTERVAL=60
# Maximum seconds per iteration before the watchdog kills it
ITERATION_TIMEOUT=600
# Number of consecutive failures before the orchestrator pauses
MAX_CONSECUTIVE_FAILURES=10
